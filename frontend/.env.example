# ============================================
# Frontend Environment Variables Configuration
# Copy this to .env and fill in your actual values
# NEVER commit .env to Git! (already in .gitignore)
# ============================================

# Backend API Base URL (REQUIRED)
# All API calls will be made to this URL.
# The app will display errors if this is not set correctly.
#
# FOR LOCAL DEVELOPMENT:
# Use the local backend server URL (must be running on this port)
VITE_API_BASE_URL=http://127.0.0.1:8001

# FOR PRODUCTION (Railway):
# Replace with your actual Railway backend deployment URL
# Get the URL from: Railway Dashboard → Backend Project → Deployments → Public URL
# Example format: https://tamilnadu-election-backend-production.up.railway.app
# Never use localhost/127.0.0.1 here for deployed builds, or mobile-network users cannot reach your backend.
# Uncomment the line below and update with your Railway URL:
# VITE_API_BASE_URL=https://your-railway-backend-url.up.railway.app

# VITE_API_URL (Alternative/Legacy)
# This is checked as a fallback if VITE_API_BASE_URL is not set.
# Preference order: VITE_API_BASE_URL > VITE_API_URL > default (http://127.0.0.1:8001)
# You can use either variable, but VITE_API_BASE_URL is recommended
# VITE_API_URL=http://127.0.0.1:8001

# Optional deployment integrity checks (recommended for production):
# If set, frontend will reject stale backend deployments that serve a different
# predictions file than expected.
# Get SHA from backend endpoint: /api/predictions/meta -> source_sha256
# Example (current local predictions_2026.csv):
# VITE_EXPECTED_PREDICTIONS_SHA256=29874056f5ef6a9884d89b5ef94f39df66ca4c33205c7287fbccf1b38b407c10
# VITE_EXPECTED_API_VERSION=2026-04-12.1
# VITE_EXPECTED_PREDICTIONS_SHA256=
# VITE_EXPECTED_API_VERSION=

# ============================================
# TROUBLESHOOTING TIPS:
# ============================================
# 1. API calls are failing?
#    - Check that backend is running: curl http://127.0.0.1:8001/api/health
#    - Verify VITE_API_BASE_URL points to the correct backend host:port
#    - Check browser console for detailed error logs (look for [API Config] messages)
#
# 2. Using Railway deployment?
#    - Ensure VITE_API_BASE_URL is set to your Railway backend URL (not localhost)
#    - Build and deploy the frontend again after changing this
#    - Monitor Railway logs for backend errors: railway logs
#
# 3. CORS or network errors?
#    - Check that backend is configured to accept requests from this frontend URL
#    - In development, the backend should allow http://127.0.0.1:5173
#    - In production, update backend CORS settings for your Railway frontend domain
