# ============================================
# Backend Environment Variables (Example Template)
# Copy this to .env and fill in your actual values
# NEVER commit .env to Git!
# ============================================

# Server Configuration (Railway provides PORT automatically)
PORT=8001
HOST=0.0.0.0

# Prediction source behavior
# 0 (default): require backend/predictions_2026.csv, fail if missing
# 1: allow fallback to backend/data_files/kerala_assembly_2026.csv
ALLOW_ASSEMBLY_FALLBACK=0

# Data Mode
# Set to 1/true/yes to use LIVE API calls for social media data
# Set to 0/false/no to use mock/cached data (recommended for testing)
USE_REAL_APIS=0

# Optional: Social Media API Keys (only needed if USE_REAL_APIS=1)

# X (Twitter) API v2 bearer token
# Get from: https://developer.twitter.com/en/portal/dashboard
X_BEARER_TOKEN=

# YouTube Data API key
# Get from: https://console.cloud.google.com/
YOUTUBE_API_KEY=

# NewsAPI key
# Get from: https://newsapi.org/
NEWS_API_KEY=
