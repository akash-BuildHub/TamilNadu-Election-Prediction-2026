# ============================================
# Backend Environment Variables (Example Template)
# Copy this to .env and fill in your actual values
# NEVER commit .env to Git!
# ============================================

# Server Configuration (Railway provides PORT automatically)
PORT=8001
HOST=0.0.0.0

# CORS: tighten this in production. For a Vercel frontend, set to your
# exact Vercel URL (no trailing slash). Comma-separated allowlist is
# supported; the server echoes whichever allowed origin matches the
# request's Origin header. Default "*" is permissive for local dev.
# Example production value:
# CORS_ALLOW_ORIGIN=https://your-app.vercel.app
CORS_ALLOW_ORIGIN=*

# Prediction source behavior
# 0 (default): require backend/dataset/predictions/predictions_2026.csv, fail if missing
# 1: allow fallback to backend/dataset/data_files/tamilnadu_assembly_2026.csv
ALLOW_ASSEMBLY_FALLBACK=0

# -------------------------------------------------------------------
# Optional: Live sentiment feature (served via /api/sentiment)
# -------------------------------------------------------------------
# Live sentiment is OFF by default. Training and prediction do NOT depend
# on it -- this flag only controls the /api/sentiment endpoint's behaviour.
#
# Set ENABLE_LIVE_SENTIMENT=1 AND provide at least one API key below to
# get real data. If the flag is false OR no keys are set, the endpoint
# still returns HTTP 200 with a clear warning and an empty data array.
ENABLE_LIVE_SENTIMENT=0

# X (Twitter) API v2 bearer token
# Get from: https://developer.twitter.com/en/portal/dashboard
X_BEARER_TOKEN=

# YouTube Data API key
# Get from: https://console.cloud.google.com/
YOUTUBE_API_KEY=

# NewsAPI key
# Get from: https://newsapi.org/
NEWS_API_KEY=51e0f6be28d342d893cca44e57511990
